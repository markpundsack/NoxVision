<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Android 12+ backup.
   Configured to exclude sensitive data (WiFi passwords, user credits) from cloud backup,
   while allowing full transfer during device-to-device migration.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive shared preferences -->
        <exclude domain="sharedpref" path="noxvision_settings.xml"/>
        <exclude domain="sharedpref" path="feature_bounties_prefs.xml"/>
    </cloud-backup>
    <!--
    <device-transfer>
        If no rules are specified here, all data is included in device-to-device transfers.
        This is desirable for seamless migration (e.g. keeping settings/credits when upgrading phone).
    </device-transfer>
    -->
</data-extraction-rules>
